<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001" author="Ravaneswaran Chinnasamy">
        <createTable tableName="employee">
            <column name="id" type="varchar2(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar2(100)"/>
        </createTable>
    </changeSet>

    <changeSet id="002" author="Ravaneswaran Chinnasamy">
        <insert tableName="employee">
            <column name="id" value="1" />
            <column name="name" value="Ravaneswaran Chinnasamy" />
        </insert>
    </changeSet>

</databaseChangeLog>